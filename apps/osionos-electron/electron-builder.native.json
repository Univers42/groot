{
  "appId": "fr.trackbinocle.osionos.native",
  "productName": "osionos",
  "executableName": "osionos",
  "directories": { "output": "dist-native" },
  "files": ["main.js", "preload.js", "renderer/**/*"],
  "extraResources": [{ "from": "native-runtime", "to": "native-runtime" }],
  "linux": {
    "target": ["deb", "AppImage"],
    "category": "Office",
    "icon": "icon.png",
    "maintainer": "Track Binocle"
  },
  "deb": { "depends": ["libgtk-3-0t64 | libgtk-3-0", "libnotify4", "libnss3", "libxss1", "libxtst6", "xdg-utils"] },
  "win": { "target": ["nsis"], "icon": "icon.png" },
  "nsis": { "oneClick": false, "perMachine": false, "allowToChangeInstallationDirectory": true, "createDesktopShortcut": true, "shortcutName": "osionos" }
}
