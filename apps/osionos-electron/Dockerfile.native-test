# Integration test image for the NATIVE edition supervisor. The postgres + postgrest
# binaries (and the pg client) come from the MOUNTED bundle (/rt) — exactly what the
# desktop app ships — so this catches missing-tool bugs the previous full-Postgres
# image hid. Just needs node + a couple of runtime libs the zonky postgres links.
FROM node:22-bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
      libssl3 libldap-2.5-0 libxml2 libreadline8 liblz4-1 libzstd1 ca-certificates \
  && rm -rf /var/lib/apt/lists/*
USER node
ENTRYPOINT ["node", "/rt/native/supervisor-run.mjs"]
