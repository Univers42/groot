---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<Layout title="Page not found — Grobase" noindex>
	<div class="gb-shell">
		<Header />
		<main id="main-content">
			<section class="gb-section">
				<div class="gb-container gb-cta-final">
					<p class="gb-kicker">404</p>
					<h1>This node isn't in the galaxy.</h1>
					<p class="gb-lede">The page you're looking for doesn't exist (or hasn't been provisioned yet).</p>
					<div class="gb-hero__ctas">
						<a class="gb-btn gb-btn--primary" href="/">Back to the product</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</div>
</Layout>
