---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import TierCard from '../components/pricing/TierCard.astro';
import TransparencyTable from '../components/pricing/TransparencyTable.astro';
import MathBreakdown from '../components/pricing/MathBreakdown.astro';
import AmortizationStory from '../components/pricing/AmortizationStory.astro';
import CapabilityMatrix from '../components/pricing/CapabilityMatrix.astro';
import Faq from '../components/pricing/Faq.astro';
import { SITE } from '../data/site';
import { TIERS } from '../data/tiers';
import { PRICING_FAQ } from '../data/faq';

const title = `Pricing — ${SITE.name}`;
const description =
	'Grobase pricing with the math shown: every tier lists what you pay AND what it costs to run — live-measured RAM × the public Fly.io rate card. From a free single binary to a multi-tenant cloud.';

const jsonLd = [
	{
		'@type': 'Product',
		name: SITE.name,
		description,
		brand: { '@type': 'Brand', name: SITE.name },
		offers: TIERS.map((t) => ({
			'@type': 'Offer',
			name: `${SITE.name} ${t.name}`,
			price: t.id === 'nano' || t.id === 'basic' ? '0' : t.retail.replace(/[^0-9–-].*$/, '').split('–')[0]?.replace('$', '') || '0',
			priceCurrency: 'USD',
			description: t.audience,
		})),
	},
	{
		'@type': 'FAQPage',
		mainEntity: PRICING_FAQ.map((f) => ({
			'@type': 'Question',
			name: f.q,
			acceptedAnswer: { '@type': 'Answer', text: f.a },
		})),
	},
];
---

<Layout title={title} description={description} image="/og/pricing.png" jsonLd={jsonLd}>
	<div class="gb-shell">
		<Header />
		<main id="main-content">
			<section class="gb-section" aria-labelledby="pricing-title">
				<div class="gb-container">
					<SectionHeading
						kicker="Radical transparency"
						title="Pricing with the math shown."
						lede="Every tier lists what you pay and what it costs us to run on Fly.io — live-measured RAM, public rate card, reproducible artifacts. The margin is part of the product page, not a secret."
						id="pricing-title"
					/>
					<div class="gb-pricing-grid">
						{TIERS.map((tier) => <TierCard tier={tier} />)}
					</div>
				</div>
			</section>

			<section class="gb-section" aria-labelledby="transparency-title">
				<div class="gb-container">
					<SectionHeading
						kicker="The full matrix"
						title="What it costs us, line by line."
						id="transparency-title"
					/>
					<TransparencyTable />
				</div>
			</section>

			<section class="gb-section" aria-labelledby="math-title">
				<div class="gb-container">
					<SectionHeading
						kicker="Here's the math"
						title="Rate card × measured RAM. That's it."
						lede="No 'contact sales to find out'. Compute ≈ ($0.77 × vCPUs) + ($5.00 × GB of RAM) — verified across every Fly shared-CPU preset."
						id="math-title"
					/>
					<MathBreakdown />
				</div>
			</section>

			<section class="gb-section" aria-labelledby="amortization-title">
				<div class="gb-container">
					<SectionHeading
						kicker="Where the margin lives"
						title="Multi-tenant changes everything."
						id="amortization-title"
					/>
					<AmortizationStory />
				</div>
			</section>

			<section class="gb-section" aria-labelledby="caps-title">
				<div class="gb-container">
					<SectionHeading
						kicker="Honest enforcement"
						title="Tiers are capability masks, not marketing labels."
						id="caps-title"
					/>
					<CapabilityMatrix />
				</div>
			</section>

			<section class="gb-section" aria-labelledby="faq-title">
				<div class="gb-container">
					<SectionHeading kicker="Questions" title="Pricing FAQ" id="faq-title" />
					<Faq items={PRICING_FAQ} />
				</div>
			</section>
		</main>
		<Footer />
	</div>
</Layout>
