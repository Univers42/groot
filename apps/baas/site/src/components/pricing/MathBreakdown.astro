---
import { FLY_RATES, TIERS } from '../../data/tiers';

// One worked example (Essential) makes the arithmetic concrete; the table
// above carries the rest.
const essential = TIERS.find((t) => t.id === 'essential')!;
---

<div class="gb-grid gb-grid--2" data-rise>
	<div class="gb-math">
		<p class="gb-kicker">The rate card (Fly.io, June 2026)</p>
		<table>
			<tbody>
				<tr><td>Shared vCPU</td><td>${FLY_RATES.sharedVcpu.toFixed(2)} / vCPU / mo</td></tr>
				<tr><td>RAM</td><td>${FLY_RATES.ramPerGb.toFixed(2)} / GB / mo</td></tr>
				<tr><td>Persistent volume</td><td>${FLY_RATES.volumePerGb.toFixed(2)} / GB / mo</td></tr>
				<tr><td>Egress (NA/EU)</td><td>${FLY_RATES.egressPerGb.toFixed(2)} / GB</td></tr>
				<tr><td>Scale-to-zero</td><td>stopped = volume only</td></tr>
			</tbody>
		</table>
	</div>
	<div class="gb-math">
		<p class="gb-kicker">Worked example — {essential.name}</p>
		<table>
			<tbody>
				<tr><td>provision</td><td>{essential.provision}</td></tr>
				<tr><td>compute</td><td>2 × $0.77 + 2 GB × $5.00 = ${essential.computeUsd.toFixed(2)}</td></tr>
				<tr><td>volume ({essential.volumeNote})</td><td>${essential.volumeUsd.toFixed(2)}</td></tr>
				<tr><td>egress</td><td>~${essential.egressUsd.toFixed(2)}</td></tr>
				<tr class="is-total"><td>all-in</td><td>{essential.allIn}</td></tr>
				<tr><td>retail</td><td>{essential.retail} — the margin is public</td></tr>
			</tbody>
		</table>
	</div>
</div>
