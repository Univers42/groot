---
import { SITE } from '../../data/site';
---

<section class="gb-section" data-galaxy-state="cta" aria-labelledby="cta-title">
	<div class="gb-container gb-cta-final">
		<p class="gb-kicker">Your node in the galaxy</p>
		<h2 id="cta-title">Compose the backend your project actually needs.</h2>
		<p class="gb-lede">
			One tenant, one binary, one weekend project — or fifty tenants on a shared Pro host at under a
			dollar each. The stack is the same. The numbers are public. The upgrade path is real.
		</p>
		<div class="gb-hero__ctas">
			<a class="gb-btn gb-btn--primary" href="/pricing/">Start free on Nano</a>
			<a class="gb-btn gb-btn--ghost" href={SITE.repoUrl} rel="noopener">Explore the source</a>
		</div>
	</div>
</section>
