---
import SectionHeading from '../ui/SectionHeading.astro';
import { TIERS } from '../../data/tiers';
---

<section class="gb-section" data-galaxy-state="tiers" aria-labelledby="editions-title">
	<div class="gb-container">
		<SectionHeading
			kicker="Five measured shapes"
			title="Pick the right amount of backend."
			lede="Not plans — shapes. Each tier is a real, repeatable deployment whose RAM is measured live and whose cost is rate-card arithmetic. Watch the galaxy cluster: most tenants are tiny, and that's the point."
			id="editions-title"
		/>
		<div class="gb-tier-row" data-rise>
			{TIERS.map((t) => (
				<a class={`gb-tier-mini tier--${t.id}`} href={`/pricing/#tier-${t.id}`}>
					<span class="gb-tier-mini__name">{t.name}</span>
					<span class="gb-tier-mini__meta">{t.ram} · {t.services}</span>
					<span class="gb-tier-mini__meta">{t.audience}</span>
					<span class="gb-tier-mini__price">{t.retail}</span>
				</a>
			))}
		</div>
	</div>
</section>
