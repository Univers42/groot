---
import SectionHeading from '../ui/SectionHeading.astro';
import DiagramIsolation from '../diagrams/DiagramIsolation.astro';
import { ISOLATION_MODELS } from '../../data/isolation';
---

<section class="gb-section" data-galaxy-state="isolation" aria-labelledby="isolation-title">
	<div class="gb-container">
		<SectionHeading
			kicker="Multi-tenant DNA"
			title="Isolation is a dial, not a rebuild."
			lede="Four isolation models, selectable per mount — dense and cheap for small tenants, hard walls for regulated ones, or the tenant's own database. The galaxy splits into the four rings."
			id="isolation-title"
		/>
		<div data-rise>
			<DiagramIsolation />
		</div>
		<ul class="gb-checklist" role="list">
			{ISOLATION_MODELS.map((m) => (
				<li>
					<strong>{m.name}</strong> — {m.how} <em>{m.cost}; {m.when.toLowerCase()}.</em>
				</li>
			))}
		</ul>
	</div>
</section>
