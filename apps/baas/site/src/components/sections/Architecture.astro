---
import SectionHeading from '../ui/SectionHeading.astro';
import DiagramPlanes from '../diagrams/DiagramPlanes.astro';
import DiagramRequestFlow from '../diagrams/DiagramRequestFlow.astro';
import { HOT_PATH } from '../../data/tiers';
---

<section class="gb-section gb-section--dim" data-galaxy-state="planes" aria-labelledby="arch-title">
	<div class="gb-container">
		<SectionHeading
			kicker="Three languages, three planes"
			title="Each plane gets the language its job deserves."
			lede={`TypeScript where business rules change daily. Go for always-up control daemons. Rust where every millisecond and mebibyte counts: the hot path went from ${HOT_PATH.oldRam} to ${HOT_PATH.newRam} — ${HOT_PATH.ramFactor}, ${HOT_PATH.latencyFactor}.`}
			id="arch-title"
		/>
		<div data-rise>
			<DiagramPlanes />
		</div>
		<div data-rise>
			<DiagramRequestFlow />
		</div>
	</div>
</section>
