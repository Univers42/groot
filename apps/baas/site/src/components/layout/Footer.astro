---
import { NAV, SITE } from '../../data/site';
const year = new Date().getFullYear();
---

<footer class="gb-footer">
	<div class="gb-container">
		<div class="gb-footer__inner">
			<div>
				<p class="gb-header__brand">{SITE.name}</p>
				<p class="gb-footer__tag">{SITE.tagline} Self-hosted, engine-agnostic, honestly priced.</p>
			</div>
			<nav aria-label="Footer">
				{NAV.map((item) => <a href={item.href}>{item.label}</a>)}
			</nav>
		</div>
		<p class="gb-footer__note">
			© {year} {SITE.name}. Every number on this site is live-measured on the real stack — not estimated, not rounded up.
		</p>
	</div>
</footer>
