---
import '../styles/main.scss';
import { SITE } from '../data/site';

type Props = {
	title?: string;
	description?: string;
	image?: string;
	canonical?: string;
	noindex?: boolean;
	/** Extra schema.org nodes appended to the JSON-LD @graph (Product, FAQPage…). */
	jsonLd?: Record<string, unknown>[];
};

const {
	title = `${SITE.name} — ${SITE.tagline}`,
	description = SITE.description,
	image = '/og/home.png',
	canonical,
	noindex = false,
	jsonLd = [],
} = Astro.props;

// Absolute URLs for canonical + social cards (Astro.site comes from astro.config).
const site = Astro.site;
const canonicalUrl = canonical ?? (site ? new URL(Astro.url.pathname, site).href : undefined);
const socialImageUrl = site ? new URL(image, site).href : image;
const graph = {
	'@context': 'https://schema.org',
	'@graph': [
		{ '@type': 'Organization', name: SITE.name, url: site?.href, logo: site ? new URL('/favicon.svg', site).href : '/favicon.svg' },
		{ '@type': 'WebSite', name: SITE.name, url: site?.href, description: SITE.description },
		...jsonLd,
	],
};

// Production CSP is generated by Astro's `security.csp` (see astro.config.mjs):
// a per-page <meta> with SHA-256 hashes for every inline script/style Astro
// emits. Astro does NOT inject a CSP during `astro dev`, so we emit an
// HMR-friendly policy there (unsafe-inline/eval + ws: for Vite live reload).
const isDev = import.meta.env.DEV;
const developmentCsp = [
	"default-src 'self'",
	"base-uri 'self'",
	"object-src 'none'",
	"form-action 'self'",
	"img-src 'self' data:",
	"worker-src 'self'",
	"manifest-src 'self'",
	"font-src 'self'",
	"style-src 'self' 'unsafe-inline'",
	"script-src 'self' 'unsafe-inline' 'unsafe-eval'",
	"connect-src 'self' http://localhost:* ws://localhost:* http://127.0.0.1:* ws://127.0.0.1:*",
].join('; ');
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="color-scheme" content="dark" />
		<meta name="theme-color" content="#05070d" />
		<meta name="description" content={description} />
		{canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
		{noindex && <meta name="robots" content="noindex, nofollow" />}

		<meta property="og:type" content="website" />
		<meta property="og:site_name" content={SITE.name} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		{canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
		<meta property="og:image" content={socialImageUrl} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={socialImageUrl} />
		<script is:inline type="application/ld+json" set:html={JSON.stringify(graph).replace(/</g, '\\u003c')} />

		{isDev && <meta http-equiv="Content-Security-Policy" content={developmentCsp} />}
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preload" href="/fonts/sora-700.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/inter-400.woff2" as="font" type="font/woff2" crossorigin />
		<title>{title}</title>
	</head>
	<body>
		<!-- Bypass block (WCAG 2.4.1): every page targets <main id="main-content">. -->
		<a href="#main-content" class="skip-link">Skip to main content</a>
		<slot />
	</body>
</html>
