{
  "uid": "mini-baas-overview",
  "title": "BaaS overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "tags": ["mini-baas", "overview"],
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate by service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (service) (rate(mini_baas_http_requests_total[5m]))", "legendFormat": "{{service}}" }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "5xx error rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (service) (rate(mini_baas_http_requests_total{status_code=~\"5..\"}[5m]))", "legendFormat": "{{service}}" }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "p95 latency",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, service) (rate(mini_baas_http_request_duration_seconds_bucket[5m])))", "legendFormat": "{{service}}" }
      ],
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 }
    }
  ]
}
