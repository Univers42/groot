{
  "uid": "mini-baas-coherence-m3",
  "title": "Coherence (M3)",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "tags": ["mini-baas", "coherence", "m3"],
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Outbox lag",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "mini_baas_outbox_pending_events", "legendFormat": "pending" }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Dead outbox events",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "increase(mini_baas_outbox_dead_events_total[5m])", "legendFormat": "dead" }
      ],
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Idempotency hit rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (service, result) (rate(mini_baas_idempotency_requests_total[5m]))", "legendFormat": "{{service}} {{result}}" }
      ],
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 }
    },
    {
      "id": 4,
      "type": "logs",
      "title": "Outbox relay logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "{service=\"outbox-relay\"}" }
      ],
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 }
    }
  ]
}
