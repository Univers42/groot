{
  "uid": "mini-baas-federation",
  "title": "Federation",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "tags": ["mini-baas", "federation"],
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Query-router operation rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (route, status_code) (rate(mini_baas_http_requests_total{service=\"query-router\"}[5m]))", "legendFormat": "{{route}} {{status_code}}" }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Adapter-registry lookups",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (route) (rate(mini_baas_http_requests_total{service=\"adapter-registry\"}[5m]))", "legendFormat": "{{route}}" }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Trino availability",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "up{job=\"trino\"}", "legendFormat": "trino" }
      ],
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 }
    }
  ]
}
